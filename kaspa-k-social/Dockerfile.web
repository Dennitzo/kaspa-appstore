FROM node:22-alpine AS builder

WORKDIR /app

RUN apk add --no-cache git

COPY . /context
RUN set -eux; \
  src=""; \
  if [ -f /context/package.json ]; then \
    src="/context"; \
  elif [ -f /context/k/package.json ]; then \
    src="/context/k"; \
  else \
    if [ -d /context/.git ]; then git -C /context checkout -f HEAD || true; fi; \
    if [ -f /context/package.json ]; then src="/context"; fi; \
    if [ -z "$src" ] && [ -d /context/k/.git ]; then git -C /context/k checkout -f HEAD || true; fi; \
    if [ -z "$src" ] && [ -f /context/k/package.json ]; then src="/context/k"; fi; \
    if [ -z "$src" ]; then \
      git clone --depth 1 https://github.com/thesheepcat/K.git /tmp/k; \
      src="/tmp/k"; \
    fi; \
  fi; \
  cp -a "$src/." /app/
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi
RUN npm run build:web

FROM nginx:1.27-alpine

COPY --from=builder /app/dist /usr/share/nginx/html
RUN printf '%s\n' \
  'server {' \
  '  listen 5173;' \
  '  server_name _;' \
  '  root /usr/share/nginx/html;' \
  '  index index.html;' \
  '  location / {' \
  '    try_files $uri $uri/ /index.html;' \
  '  }' \
  '}' > /etc/nginx/conf.d/default.conf

EXPOSE 5173
CMD ["nginx", "-g", "daemon off;"]
